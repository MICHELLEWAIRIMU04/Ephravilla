# ─────────────────────────────────────────────────────────────────────────────
# Ephravilla Construction — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://ephravilla.com

# WhatsApp number in E.164 format — no + prefix, no spaces
NEXT_PUBLIC_WHATSAPP_NUMBER=254798900032

# Email delivery (choose one)
# Option A — Resend (recommended): https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B — SMTP (Nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=website@ephravilla.com
# SMTP_TO=accounts@ephravilla.com
